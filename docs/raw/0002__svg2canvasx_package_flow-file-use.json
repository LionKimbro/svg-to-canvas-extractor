{
  "document": {
    "document-id": "svg2canvasx.flow-file-and-package-use.raw.v1",
    "title": "svg2canvasx Flow Files and Flow-Oriented Package Functions",
    "tags": [
      "svg2canvasx",
      "flow",
      "json",
      "softspec",
      "tkinter",
      "canvas",
      "package"
    ],
    "purpose": "Describe the svg2canvasx flow JSON format and the package functions used to create, load, preview, and render flow documents onto Tkinter canvases and Toplevel windows.",
    "status": "draft",
    "created": "2026-06-02",
    "updated": "2026-06-02"
  },
  "overview": {
    "description": "The flow format is a simplified JSON representation derived from the Stage 1 extracted SVG JSON. It is oriented around drawing-ready layers and items rather than raw SVG structure. The package provides helpers to convert extracted data into flow form, load flow files, draw flow items onto a Tkinter Canvas, create a Canvas already populated from a flow document, create a Tkinter Toplevel window containing such a Canvas, and generate raw Tkinter source code from a flow document.",
    "core-ideas": [
      "Flow documents are a post-extraction representation, not a replacement for the extracted JSON.",
      "Flow documents are intentionally simpler than SVG and are designed for package-internal drawing, previews, and code generation.",
      "Presentation layers contain drawable `items`.",
      "Annotation layers contain `regions`.",
      "The flow representation is easy to convert back into preview objects and easy to emit as raw Canvas calls."
    ]
  },
  "package-functions": {
    "flow-conversion": [
      {
        "name": "convert_extracted_file_to_flow",
        "location": "src/svg2canvasx/flow.py",
        "signature": "convert_extracted_file_to_flow(path)",
        "description": "Load an extracted JSON file from disk and convert it into a flow document."
      },
      {
        "name": "convert_extracted_data_to_flow",
        "location": "src/svg2canvasx/flow.py",
        "signature": "convert_extracted_data_to_flow(data)",
        "description": "Convert an already-loaded extracted JSON dictionary into a flow dictionary."
      },
      {
        "name": "load_flow_file",
        "location": "src/svg2canvasx/flow.py",
        "signature": "load_flow_file(path)",
        "description": "Load a flow JSON file from disk and return the parsed dictionary."
      }
    ],
    "flow-preview-and-canvas-use": [
      {
        "name": "draw_flow_on_canvas",
        "location": "src/svg2canvasx/flow.py",
        "signature": "draw_flow_on_canvas(canvas, flow_data)",
        "description": "Draw presentation-layer flow items onto an existing Tkinter Canvas.",
        "notes": [
          "This function assumes the Canvas already exists.",
          "It only draws `presentation` layers, not annotation layers."
        ]
      },
      {
        "name": "create_canvas_for_flow",
        "location": "src/svg2canvasx/flow.py",
        "signature": "create_canvas_for_flow(parent, flow_data)",
        "description": "Create a Tkinter Canvas under `parent`, size it from `flow_data.canvas`, draw the flow items, pack it, and return the Canvas."
      },
      {
        "name": "create_toplevel_for_flow",
        "location": "src/svg2canvasx/flow.py",
        "signature": "create_toplevel_for_flow(root, flow_data)",
        "description": "Create a Tkinter `Toplevel`, create a Canvas inside it from the flow data, and return a dictionary containing both objects.",
        "return-structure": {
          "toplevel": "The created Tkinter.Toplevel instance.",
          "canvas": "The Canvas created inside the Toplevel."
        }
      },
      {
        "name": "flow_to_preview_data",
        "location": "src/svg2canvasx/flow.py",
        "signature": "flow_to_preview_data(data)",
        "description": "Convert a flow document into the preview JSON shape used by the preview renderer."
      }
    ],
    "flow-to-source-code": [
      {
        "name": "generate_rawtkinter_source",
        "location": "src/svg2canvasx/flow.py",
        "signature": "generate_rawtkinter_source(flow_data)",
        "description": "Generate Python source for a `draw(canvas)` function that replays the flow document using raw Canvas calls."
      }
    ]
  },
  "usage-patterns": {
    "using-a-flow-file-with-an-existing-canvas": {
      "description": "Use this when your application already owns the Tk root/window and Canvas lifecycle.",
      "example": [
        "from svg2canvasx.flow import draw_flow_on_canvas, load_flow_file",
        "",
        "flow_data = load_flow_file(\"flow.json\")",
        "draw_flow_on_canvas(canvas, flow_data)"
      ]
    },
    "creating-a-canvas-for-a-flow": {
      "description": "Use this when you want the package to create and pack the Canvas for you.",
      "example": [
        "from svg2canvasx.flow import create_canvas_for_flow, load_flow_file",
        "",
        "flow_data = load_flow_file(\"flow.json\")",
        "canvas = create_canvas_for_flow(parent, flow_data)"
      ]
    },
    "creating-a-toplevel-window-for-a-flow": {
      "description": "Use this when you want a separate Tkinter.Toplevel window that contains the rendered flow.",
      "example": [
        "from svg2canvasx.flow import create_toplevel_for_flow, load_flow_file",
        "",
        "flow_data = load_flow_file(\"flow.json\")",
        "created = create_toplevel_for_flow(root, flow_data)",
        "window = created[\"toplevel\"]",
        "canvas = created[\"canvas\"]"
      ]
    },
    "converting-extracted-json-to-flow-in-memory": {
      "description": "Use this when extraction has already happened and you want the flow representation without writing intermediate files.",
      "example": [
        "from svg2canvasx.flow import convert_extracted_data_to_flow",
        "",
        "flow_data = convert_extracted_data_to_flow(extracted_data)"
      ]
    }
  },
  "softspec": {
    "types": {
      "paint": {
        "type": "string-or-null",
        "description": "A drawing paint value such as a color string, or null for no paint.",
        "examples": [
          "#000000",
          "#ffffff",
          null
        ]
      },
      "point2": {
        "type": "array",
        "description": "A two-number point `[x, y]`.",
        "items": "number",
        "constraints": {
          "length": 2
        },
        "examples": [
          [
            10.0,
            20.0
          ]
        ]
      },
      "bbox4": {
        "type": "array",
        "description": "A four-number bounding box `[x0, y0, x1, y1]`.",
        "items": "number",
        "constraints": {
          "length": 4
        },
        "examples": [
          [
            10.0,
            20.0,
            100.0,
            120.0
          ]
        ]
      }
    },
    "schemas": {
      "flow-document": {
        "title": "svg2canvasx Flow Document",
        "description": "A drawing-oriented JSON document derived from extracted SVG JSON.",
        "structure": {
          "type": "object",
          "keys": {
            "format": {
              "type": "string",
              "required": true,
              "description": "Format marker for the document.",
              "examples": [
                "svg2canvasx-flow"
              ]
            },
            "version": {
              "type": "number",
              "required": true,
              "description": "Flow format version.",
              "examples": [
                1
              ]
            },
            "source": {
              "type": "object",
              "required": false,
              "description": "Source provenance for the flow document.",
              "keys": {
                "path": {
                  "type": "string",
                  "required": false,
                  "description": "Original extracted/source path."
                },
                "extracted_from": {
                  "type": "string",
                  "required": false,
                  "description": "Path to the extracted JSON that was converted."
                }
              },
              "additional_keys": true
            },
            "canvas": {
              "type": "object",
              "required": false,
              "description": "Canvas sizing metadata.",
              "keys": {
                "width": {
                  "type": "number",
                  "required": false
                },
                "height": {
                  "type": "number",
                  "required": false
                },
                "viewBox": {
                  "type": "array",
                  "required": false,
                  "description": "Original SVG viewBox when available."
                }
              },
              "additional_keys": true
            },
            "layers": {
              "type": "array",
              "required": true,
              "description": "Ordered list of flow layers.",
              "items": "flow-layer"
            }
          },
          "additional_keys": true
        }
      },
      "flow-layer": {
        "title": "Flow Layer",
        "description": "A layer in the flow document. Presentation layers contain `items`. Annotation layers contain `regions`.",
        "structure": {
          "type": "object",
          "keys": {
            "name": {
              "type": "string",
              "required": true,
              "description": "Human-readable layer name."
            },
            "role": {
              "type": "string",
              "required": true,
              "description": "Layer role.",
              "vocabulary": {
                "presentation": "Drawable items intended for normal rendering.",
                "annotation": "Annotation regions or similar overlay metadata."
              }
            },
            "items": {
              "type": "array",
              "required": "required when role is presentation",
              "items": "presentation-item"
            },
            "regions": {
              "type": "array",
              "required": "required when role is annotation",
              "items": "annotation-region"
            }
          },
          "additional_keys": true
        }
      },
      "presentation-item": {
        "title": "Presentation Item",
        "description": "A drawing-oriented item in a presentation layer.",
        "structure": {
          "type": "object",
          "keys": {
            "kind": {
              "type": "string",
              "required": true,
              "description": "Shape or item type.",
              "examples": [
                "rect",
                "line",
                "path",
                "polyline",
                "polygon",
                "circle",
                "ellipse",
                "text"
              ]
            },
            "label": {
              "type": "string",
              "required": false,
              "description": "Optional label or identifier."
            },
            "bbox": {
              "type": "bbox4",
              "required": false,
              "description": "Bounding box for bbox-based items."
            },
            "points": {
              "type": "array",
              "required": false,
              "description": "Point list for line-like items or rotated rectangles.",
              "items": "point2"
            },
            "closed": {
              "type": "boolean",
              "required": false,
              "description": "Whether a line-like item should be treated as closed."
            },
            "draw": {
              "type": "object",
              "required": false,
              "description": "Stroke/fill/dash drawing properties.",
              "keys": {
                "stroke": {
                  "type": "paint",
                  "required": false
                },
                "fill": {
                  "type": "paint",
                  "required": false
                },
                "stroke_width": {
                  "type": "number",
                  "required": false
                },
                "dash": {
                  "type": "array",
                  "required": false,
                  "items": "number"
                }
              },
              "additional_keys": true
            },
            "text": {
              "type": "string",
              "required": "used for text items",
              "description": "Text content."
            },
            "point": {
              "type": "point2",
              "required": "used for text items",
              "description": "Anchor point for text."
            },
            "text_style": {
              "type": "object",
              "required": "used for text items",
              "description": "Text drawing properties.",
              "keys": {
                "font_family": {
                  "type": "string",
                  "required": false
                },
                "font_size": {
                  "type": "number",
                  "required": false
                },
                "bold": {
                  "type": "boolean",
                  "required": false
                },
                "italic": {
                  "type": "boolean",
                  "required": false
                },
                "anchor": {
                  "type": "string",
                  "required": false
                },
                "angle": {
                  "type": "number",
                  "required": false
                },
                "fill": {
                  "type": "paint",
                  "required": false
                }
              },
              "additional_keys": true
            }
          },
          "additional_keys": true
        }
      },
      "annotation-region": {
        "title": "Annotation Region",
        "description": "A simple annotation region derived from annotation-layer objects.",
        "structure": {
          "type": "object",
          "keys": {
            "label": {
              "type": "string",
              "required": false
            },
            "name": {
              "type": "string",
              "required": false
            },
            "shape": {
              "type": "string",
              "required": false,
              "examples": [
                "rect",
                "bbox"
              ]
            },
            "bbox": {
              "type": "bbox4",
              "required": true
            }
          },
          "additional_keys": true
        }
      }
    }
  },
  "examples": {
    "minimal-flow-document": {
      "format": "svg2canvasx-flow",
      "version": 1,
      "source": {
        "path": "extracted.json",
        "extracted_from": "extracted.json"
      },
      "canvas": {
        "width": 1000,
        "height": 800,
        "viewBox": [
          0,
          0,
          1000,
          800
        ]
      },
      "layers": [
        {
          "name": "Layer 2: schematic objects",
          "role": "presentation",
          "items": [
            {
              "kind": "rect",
              "label": "button.export_json",
              "bbox": [
                50,
                50,
                250,
                90
              ],
              "draw": {
                "stroke": "#000000",
                "fill": "#ffffff",
                "stroke_width": 2.0,
                "dash": null
              }
            },
            {
              "kind": "text",
              "label": "text.export_json",
              "text": "Export JSON",
              "point": [
                150,
                80
              ],
              "text_style": {
                "font_family": "Arial",
                "font_size": 32.0,
                "bold": false,
                "italic": false,
                "anchor": "s",
                "angle": 0.0,
                "fill": "#000000"
              }
            }
          ]
        }
      ]
    }
  },
  "notes-and-caveats": {
    "notes": [
      "The flow format is currently defined by package behavior rather than a frozen standalone standard.",
      "The structure is intentionally soft: additional keys are acceptable unless a consuming tool requires a narrower subset.",
      "The package's Canvas/Toplevel helpers draw only presentation layers by default.",
      "Annotation layers are still represented in flow JSON, even when a specific helper does not draw them."
    ],
    "relationship-to-other-formats": [
      "Extracted JSON is richer and closer to SVG provenance.",
      "Flow JSON is simpler and more drawing-oriented.",
      "Raw Tkinter source is generated from flow JSON, not directly from extracted JSON."
    ]
  }
}
